doctype html
html(lang="en")
    head
        title Login | ReShare
        //- TWEAK 1: Absolute path to the public folder
        link(rel="stylesheet", href="/style.css")

    body
        div.wrapper
            //- Professional Modular Navigation
            include ./includes/nav.pug

            h1.page-title Sign In to ReShare

            .form-container
                .form-card
                    h3 Welcome Back
                    
                    //- TWEAK 2: Points to the new auth controller router
                    form(action="/authenticate", method="POST")
                        div.form-group
                            label(for="email") Email Address
                            input(type="email", id="email", name="email", placeholder="Enter your email", required)

                        div.form-group
                            label(for="password") Password
                            input(type="password", id="password", name="password", placeholder="Enter password", required)

                        button.login-btn(type="submit") Login
                    
                    p.form-footer 
                        | New to ReShare? 
                        a(href="/signup") Create an account

            //- Documentation Link: Ties code to requirements
            .user-story
                strong User Story:
                |  "As a registered user, I want to log in securely so that I can manage my listings and messages."